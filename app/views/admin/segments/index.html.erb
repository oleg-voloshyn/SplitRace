<div class="page-header">
  <h1>Segments</h1>
  <%= link_to "+ New Segment", new_admin_segment_path, class: "btn btn-danger" %>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th class="ps-3">Name</th>
          <th>Distance</th>
          <th>City</th>
          <th>Active</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @segments.each do |s| %>
          <tr>
            <td class="ps-3 fw-semibold"><%= s.name %></td>
            <td><%= s.distance_meters ? "#{(s.distance_meters / 1000.0).round(2)} km" : "—" %></td>
            <td><%= [s.city, s.country].compact.join(", ").presence || "—" %></td>
            <td>
              <% if s.is_active %>
                <span class="badge bg-success">Active</span>
              <% else %>
                <span class="badge bg-secondary">Inactive</span>
              <% end %>
            </td>
            <td class="text-muted"><%= s.created_at.strftime("%d %b %Y") %></td>
            <td class="text-end pe-3">
              <%= link_to "Edit", edit_admin_segment_path(s), class: "btn btn-sm btn-outline-secondary me-1" %>
              <%= button_to "Delete", admin_segment_path(s), method: :delete,
                    form: { data: { turbo_confirm: "Delete #{s.name}?" } },
                    class: "btn btn-sm btn-outline-danger" %>
            </td>
          </tr>
        <% end %>
        <% if @segments.empty? %>
          <tr><td colspan="6" class="text-center text-muted py-4">No segments yet. <a href="<%= new_admin_segment_path %>">Create one →</a></td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
