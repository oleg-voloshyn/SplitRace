<script>
(function() {
  const waypointsField = document.getElementById('waypoints-json');
  const cityField = document.getElementById('segment-city');
  const countryField = document.getElementById('segment-country');
  const locationLabel = document.getElementById('segment-location');
  const EXISTING = JSON.parse(waypointsField.value || '[]');
  const DEFAULT_CENTER = [50.45, 30.52];

  const map = L.map('segment-map').setView(DEFAULT_CENTER, 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
  }).addTo(map);

  let waypoints = [];
  let markers   = [];
  let polyline  = null;
  let geocodeTimer = null;
  let lastGeocodeKey = null;

  function redraw() {
    markers.forEach(m => map.removeLayer(m));
    markers = [];
    if (polyline) { map.removeLayer(polyline); polyline = null; }

    waypoints.forEach((pt, i) => {
      const isFirst = i === 0;
      const isLast  = i === waypoints.length - 1;
      const color   = isFirst ? '#4caf50' : isLast ? '#e53935' : '#1976d2';
      const radius  = (isFirst || isLast) ? 9 : 5;

      const m = L.circleMarker([pt.lat, pt.lng], {
        radius, color, fillColor: color, fillOpacity: 0.9, weight: 2
      }).bindTooltip(isFirst ? 'Start' : isLast ? 'Finish' : '#' + (i+1), { permanent: false }).addTo(map);

      if (isLast && waypoints.length > 1) {
        m.on('click', function(e) {
          L.DomEvent.stopPropagation(e);
          waypoints.pop();
          redraw();
          save();
        });
        m.getElement()?.style.setProperty('cursor', 'pointer');
      }
      markers.push(m);
    });

    if (waypoints.length > 1) {
      polyline = L.polyline(waypoints.map(p => [p.lat, p.lng]), {
        color: '#e53935', weight: 4, opacity: 0.85
      }).addTo(map);
    }

    document.getElementById('point-count').textContent = waypoints.length;
    if (waypoints.length > 1) {
      const dist = haversineTotal(waypoints);
      document.getElementById('segment-distance').textContent = (dist / 1000).toFixed(2) + ' km';
    } else {
      document.getElementById('segment-distance').textContent = '—';
    }
  }

  function save() {
    document.getElementById('waypoints-json').value = JSON.stringify(waypoints);
    scheduleLocationLookup();
  }

  function setLocation(city, country) {
    cityField.value = city || '';
    countryField.value = country || '';
    locationLabel.textContent = [city, country].filter(Boolean).join(', ') || '—';
  }

  function scheduleLocationLookup() {
    clearTimeout(geocodeTimer);
    if (waypoints.length === 0) {
      lastGeocodeKey = null;
      setLocation('', '');
      return;
    }

    const first = waypoints[0];
    const key = first.lat.toFixed(5) + ',' + first.lng.toFixed(5);
    if (key === lastGeocodeKey && (cityField.value || countryField.value)) return;

    geocodeTimer = setTimeout(function() {
      reverseGeocode(first, key);
    }, 350);
  }

  function reverseGeocode(point, key) {
    lastGeocodeKey = key;
    locationLabel.textContent = 'Detecting...';

    const url = new URL('https://nominatim.openstreetmap.org/reverse');
    url.searchParams.set('format', 'jsonv2');
    url.searchParams.set('lat', point.lat);
    url.searchParams.set('lon', point.lng);
    url.searchParams.set('accept-language', 'en');

    fetch(url.toString())
      .then(response => response.ok ? response.json() : null)
      .then(data => {
        const address = data?.address || {};
        const city = address.city || address.town || address.village || address.municipality || address.county || '';
        const country = (address.country_code || '').toUpperCase() || address.country || '';
        setLocation(city, country);
      })
      .catch(function() {
        setLocation('', '');
      });
  }

  map.on('click', function(e) {
    waypoints.push({ lat: e.latlng.lat, lng: e.latlng.lng });
    redraw();
    save();
  });

  document.getElementById('undo-btn').addEventListener('click', function() {
    if (waypoints.length > 0) { waypoints.pop(); redraw(); save(); }
  });

  document.getElementById('clear-btn').addEventListener('click', function() {
    const clearWaypoints = function() { waypoints = []; redraw(); save(); };
    if (window.SplitRaceAdminConfirm) {
      window.SplitRaceAdminConfirm.show({
        title: 'Clear route',
        message: 'Clear all waypoints?',
        confirmText: 'Clear',
        onConfirm: clearWaypoints
      });
    } else if (confirm('Clear all waypoints?')) {
      clearWaypoints();
    }
  });

  function haversineTotal(pts) {
    let total = 0;
    for (let i = 1; i < pts.length; i++) total += haversine(pts[i-1], pts[i]);
    return total;
  }

  function haversine(a, b) {
    const R = 6371000, rad = Math.PI / 180;
    const dlat = (b.lat - a.lat) * rad, dlng = (b.lng - a.lng) * rad;
    const x = Math.sin(dlat/2)**2 + Math.cos(a.lat*rad)*Math.cos(b.lat*rad)*Math.sin(dlng/2)**2;
    return R * 2 * Math.asin(Math.sqrt(x));
  }

  if (EXISTING.length > 0) {
    waypoints = EXISTING;
    redraw();
    save();
    map.fitBounds(waypoints.map(p => [p.lat, p.lng]), { padding: [30, 30] });
  } else if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      function(position) {
        const current = [position.coords.latitude, position.coords.longitude];
        map.setView(current, 15);
        L.circleMarker(current, {
          radius: 7,
          color: '#1976d2',
          fillColor: '#1976d2',
          fillOpacity: 0.85,
          weight: 2
        }).bindTooltip('Your location', { permanent: false }).addTo(map);
      },
      function() {},
      { enableHighAccuracy: false, timeout: 8000, maximumAge: 300000 }
    );
  }
})();
</script>
