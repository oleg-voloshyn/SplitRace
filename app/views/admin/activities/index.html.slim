.page-header
  h1
    | Activities
    - if @user
      span.text-muted.fs-5
        | &nbsp;— #{@user.full_name}
  - if @user
    = link_to "← All users", admin_users_path, class: "btn btn-outline-secondary"

.mb-3
  = link_to "All", admin_activities_path(user_id: params[:user_id]), class: "btn btn-sm #{params[:suspicious] == '1' ? 'btn-outline-dark' : 'btn-dark'} me-2"
  = link_to "Suspicious", admin_activities_path(user_id: params[:user_id], suspicious: "1"), class: "btn btn-sm #{params[:suspicious] == '1' ? 'btn-danger' : 'btn-outline-danger'}"

.card
  .card-body.p-0
    table.table.table-hover.mb-0
      thead.table-light
        tr
          th.ps-3 Date
          th User
          th Distance
          th Time
          th Pace
          th Segments
          th Source
          th GPS
          th
      tbody
        - if @activities.empty?
          tr
            td colspan="9" class="text-muted text-center py-4" No activities yet
        - @activities.each do |a|
          tr
            td.ps-3= a.started_at&.strftime("%d %b %Y %H:%M")
            td
              = link_to a.user.full_name, admin_activities_path(user_id: a.user_id), class: "text-decoration-none"
              br
              span.text-muted.small= a.user.email
            td.text-muted= a.distance_meters ? "#{(a.distance_meters / 1000.0).round(2)} km" : "—"
            td.text-muted= format_seconds(a.elapsed_time_seconds)
            td.text-muted= format_pace(a.elapsed_time_seconds, a.distance_meters)
            td
              - count = a.segment_efforts.size
              - if count > 0
                span.badge.bg-warning.text-dark= count
              - else
                span.text-muted —
            td.text-muted.small= a.source
            td
              - if a.suspicious?
                span.badge.bg-danger Suspicious
              - else
                span.badge.bg-success OK
            td.text-end.pe-3
              = link_to "View", admin_activity_path(a), class: "btn btn-sm btn-outline-secondary"
