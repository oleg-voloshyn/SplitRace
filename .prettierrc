{
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "bracketSpacing": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "semi": true,
  "singleQuote": true,
  "useTabs": false,
  "printWidth": 120,
  "importOrder": ["^react$", "<THIRD_PARTY_MODULES>", "^[../]", "^[./]"],
  "importOrderSeparation": false,
  "importOrderSortSpecifiers": true
}
